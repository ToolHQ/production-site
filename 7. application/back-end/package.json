{
  "name": "my-project",
  "version": "1.0.0",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "local-start": "node --env-file=./.env --enable-source-maps --inspect=0.0.0.0:9229 dist/app.js",
    "start": "node --enable-source-maps --inspect=0.0.0.0:9229 dist/app.js",
    "lint": "eslint .",
    "build": "npm run generate-schema && tsc",
    "generate-schema": "node generate-schema.js",
    "build-start": "npm run build && npm run start",
    "local-build-start": "npm run build && npm run local-start",
    "local-watch-build-start": "nodemon --ignore dist --ignore schemas --ignore **/exportedSchemas.ts --ext ts,json --exec npm run local-build-start",
    "watch-build-start": "nodemon --ignore dist --ignore schemas --ignore **/exportedSchemas.ts --ext ts,json --exec npm run build-start"
  },
  "dependencies": {
    "@dnorio/db-wrapper": "0.0.172",
    "@dnorio/httpclient": "0.0.172",
    "@dnorio/logger": "0.0.172",
    "@dnorio/models-generator": "0.0.172",
    "@dnorio/models-toolhq": "0.0.172",
    "@dnorio/pg-query-binding": "0.0.172",
    "@dnorio/swagger-router": "0.0.172",
    "@types/express": "5.0.0",
    "ajv": "8.17.1",
    "ajv-formats": "3.0.1",
    "elastic-apm-node": "4.10.0",
    "express": "4.21.2",
    "pg": "8.13.1",
    "socks-proxy-agent": "8.0.5",
    "typescript": "5.4.5",
    "typescript-json-schema": "0.64.0"
  },
  "devDependencies": {
    "@eslint/js": "9.18.0",
    "@types/eslint__js": "8.42.3",
    "@types/node": "22.10.5",
    "@types/pg": "8.11.10",
    "eslint": "8.57.0",
    "nodemon": "3.1.9",
    "typescript-eslint": "7.13.0"
  },
  "sideEffects": false
}
