    "elastic-apm-node": "4.5.4",
    "express": "4.19.2"
  },
  "devDependencies": {
    "nodemon": "3.1.0",
    "prettier": "3.2.5",
    "ts-loader": "9.5.1",
    "typescript": "5.4.5",
    "webpack": "5.91.0",
    "webpack-cli": "5.1.4"
  }
}
