# syntax=docker/dockerfile:1.7
#
# AI Radar вЂ” HTTP API image.
#
# Multi-stage, multi-arch (linux/amd64 and linux/arm64). Final stage uses
# Google's distroless `cc-debian12:nonroot` so we get glibc (required by
# SQLx + reqwest with rustls + chrono tzdata) without a shell or package
# manager. SQLx is built with rustls, so no openssl-sys / native-tls.

# в”Ђв”Ђ Builder в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
FROM --platform=$BUILDPLATFORM rust:1.88-slim-bookworm AS builder

ARG TARGETARCH
ARG TARGETOS
ARG BUILDPLATFORM
ARG TARGETPLATFORM

ENV CARGO_TERM_COLOR=never \
    CARGO_INCREMENTAL=0 \
    RUSTFLAGS="-C strip=symbols" \
    DEBIAN_FRONTEND=noninteractive

# Build-essential plus cross-gcc only when BUILDPLATFORM differs from TARGET
# so `cargo build --target вЂ¦` emits the correct ELF (avoids amd64 binaries in arm64 manifests).
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
    build-essential pkg-config \
 && ARCH="$(uname -m)" \
 && if [ "$ARCH" = "x86_64" ] && [ "$TARGETARCH" = "arm64" ]; then \
      apt-get install -y --no-install-recommends gcc-aarch64-linux-gnu ; \
    elif [ "$ARCH" = "aarch64" ] && [ "$TARGETARCH" = "amd64" ]; then \
      apt-get install -y --no-install-recommends gcc-x86-64-linux-gnu ; \
    fi \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

# Map Dockerfile TARGETARCH (amd64/arm64) to Rust triple + optional cargo linker stanza for cross builds.
RUN set -eux; \
  case "$TARGETARCH" in \
    amd64) RUST_TARGET=x86_64-unknown-linux-gnu; LINKER=x86_64-linux-gnu-gcc ;; \
    arm64) RUST_TARGET=aarch64-unknown-linux-gnu; LINKER=aarch64-linux-gnu-gcc ;; \
    *) echo >&2 "unsupported TARGETARCH=$TARGETARCH"; exit 1 ;; \
  esac; \
  echo "$RUST_TARGET" > rust-target.txt; \
  rustup target add "$RUST_TARGET"; \
  ARCH="$(uname -m)"; \
  NEED_CROSS=0; \
  case "$ARCH" in \
    x86_64) [ "$TARGETARCH" != "amd64" ] && NEED_CROSS=1 ;; \
    aarch64) [ "$TARGETARCH" != "arm64" ] && NEED_CROSS=1 ;; \
    *) echo >&2 "unexpected builder uname $ARCH"; exit 1 ;; \
  esac; \
  if [ "$NEED_CROSS" -eq 1 ]; then \
    mkdir -p .cargo; \
    printf '[target.%s]\nlinker = "%s"\n' "$RUST_TARGET" "$LINKER" > .cargo/config.toml; \
  fi

# Copy manifests first so Docker layer cache is reused while sources change.
COPY Cargo.toml Cargo.lock rust-toolchain.toml ./
COPY crates/ai-radar-core/Cargo.toml crates/ai-radar-core/Cargo.toml
COPY crates/ai-radar-api/Cargo.toml  crates/ai-radar-api/Cargo.toml
COPY crates/ai-radar-cli/Cargo.toml  crates/ai-radar-cli/Cargo.toml

# Stub source files so `cargo fetch` and a deps-only build can resolve.
RUN mkdir -p crates/ai-radar-core/src crates/ai-radar-api/src crates/ai-radar-cli/src \
 && echo 'pub const VERSION: &str = "0.0.0-stub";' > crates/ai-radar-core/src/lib.rs \
 && printf 'fn main() {}\n' > crates/ai-radar-api/src/main.rs \
 && printf 'fn main() {}\n' > crates/ai-radar-cli/src/main.rs

RUN cargo fetch --locked

# Build only the API binary so other crates' deps stay in cache anyway.
RUN RUST_TARGET="$(cat rust-target.txt)" \
 && cargo build --release --locked --bin ai-radar-api --target "$RUST_TARGET"

# Replace the stubs with the real source tree, then rebuild.
COPY crates/ crates/
COPY migrations/ migrations/

# Bust the cargo cache for our own crates so they actually rebuild.
RUN find crates -name '*.rs' -exec touch {} +
RUN RUST_TARGET="$(cat rust-target.txt)" \
 && cargo build --release --locked --bin ai-radar-api --target "$RUST_TARGET" \
 && cp "target/$RUST_TARGET/release/ai-radar-api" /workspace/ai-radar-api.binary

# в”Ђв”Ђ Runtime в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
FROM --platform=$TARGETPLATFORM gcr.io/distroless/cc-debian12:nonroot AS runtime

LABEL org.opencontainers.image.title="ai-radar-api" \
      org.opencontainers.image.description="AI Radar Decision Engine вЂ” HTTP API" \
      org.opencontainers.image.source="https://github.com/dnorio/production-site" \
      org.opencontainers.image.licenses="MIT"

WORKDIR /app

COPY --from=builder /workspace/ai-radar-api.binary /usr/local/bin/ai-radar-api

ENV AI_RADAR_API_BIND=0.0.0.0:8080 \
    AI_RADAR_LOG_LEVEL=info

EXPOSE 8080
USER nonroot:nonroot

ENTRYPOINT ["/usr/local/bin/ai-radar-api"]
