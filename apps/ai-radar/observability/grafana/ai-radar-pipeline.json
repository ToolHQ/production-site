{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "AI Radar Console",
      "type": "link",
      "url": "https://ai-radar.dnor.io/"
    }
  ],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "ai_radar_pending_raw_items{namespace=\"ai-radar\"}",
          "legendFormat": "pending",
          "refId": "A"
        }
      ],
      "title": "Fila extract (pending raw_items)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(ai_radar_collected_total{namespace=\"ai-radar\"}[5m]))",
          "legendFormat": "collected/s",
          "refId": "A"
        }
      ],
      "title": "Collect rate (total)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "targets": [
        {
          "expr": "sum(rate(ai_radar_extracted_total{namespace=\"ai-radar\"}[5m]))",
          "legendFormat": "extracted/s",
          "refId": "A"
        }
      ],
      "title": "Extract rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "targets": [
        {
          "expr": "sum(rate(ai_radar_scored_total{namespace=\"ai-radar\"}[5m]))",
          "legendFormat": "scored/s",
          "refId": "A"
        }
      ],
      "title": "Score rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(ai_radar_collected_total{namespace=\"ai-radar\"}[5m])) by (source_type)",
          "legendFormat": "{{source_type}}",
          "refId": "A"
        }
      ],
      "title": "Collect por source_type",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 6,
      "targets": [
        {
          "expr": "sum(rate(ai_radar_errors_total{namespace=\"ai-radar\"}[5m])) by (stage)",
          "legendFormat": "{{stage}}",
          "refId": "A"
        }
      ],
      "title": "Erros por stage",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "id": 7,
      "targets": [
        {
          "expr": "sum(rate(ai_radar_extract_failed_total{namespace=\"ai-radar\"}[5m]))",
          "legendFormat": "extract_failed",
          "refId": "A"
        },
        {
          "expr": "sum(rate(ai_radar_score_failed_total{namespace=\"ai-radar\"}[5m]))",
          "legendFormat": "score_failed",
          "refId": "B"
        }
      ],
      "title": "Falhas extract / score",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "id": 8,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ai_radar_stage_duration_seconds_bucket{namespace=\"ai-radar\"}[5m])) by (le, stage))",
          "legendFormat": "p95 {{stage}}",
          "refId": "A"
        }
      ],
      "title": "Duração p95 por stage",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 21 },
      "id": 9,
      "targets": [
        {
          "expr": "sum(rate(ai_radar_entries_rejected_total{namespace=\"ai-radar\"}[5m])) by (reason)",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "title": "Entradas rejeitadas (ex. oversize)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          },
          "max": 100,
          "min": 0,
          "unit": "percent"
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 28 },
      "id": 10,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "ai_radar_embeddings_coverage_pct{namespace=\"ai-radar\"}",
          "legendFormat": "coverage",
          "refId": "A"
        }
      ],
      "title": "Cobertura semântica (%)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 28 },
      "id": 11,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "ai_radar_embeddings_pending{namespace=\"ai-radar\"}",
          "legendFormat": "pending",
          "refId": "A"
        }
      ],
      "title": "Fila embed (pendentes)",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["ai-radar", "pipeline"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "label": "Prometheus",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "AI Radar — Pipeline",
  "uid": "ai-radar-pipeline",
  "version": 1
}
