# AI Radar — example environment file.
# Copy to .env for local development. Never commit .env (see .gitignore).

# ── HTTP API ──────────────────────────────────────────────────────────────
AI_RADAR_API_BIND=0.0.0.0:8080
AI_RADAR_LOG_LEVEL=info
# Optional: RUST_LOG overrides AI_RADAR_LOG_LEVEL with full directives, e.g.:
# RUST_LOG=ai_radar=debug,tower_http=info,info

# ── Database (T-160) ──────────────────────────────────────────────────────
# Schema "ai_radar" is created by SQLx migrations.
#
# IMPORTANT: the URL pins `search_path=public` so SQLx stores its
# `_sqlx_migrations` bookkeeping table in `public` rather than `ai_radar`.
# Without this, `sqlx migrate revert` cycles become unstable because the
# ledger drifts between schemas. Migrations always reference tables with
# the `ai_radar.` prefix so the search path does not affect them.
DATABASE_URL=postgres://ai_radar:ai_radar@localhost:5432/ai_radar?options=-csearch_path%3Dpublic
# Host port for the docker-compose Postgres service. Override when 5432 is
# already taken on your machine, e.g. AI_RADAR_PG_HOST_PORT=5433.
AI_RADAR_PG_HOST_PORT=5432

# ── LLM provider (T-164+) ─────────────────────────────────────────────────
# Default OFF: pipeline runs in deterministic-only mode.
LLM_ENABLED=false
LLM_BASE_URL=https://openrouter.ai/api/v1
# Free-tier suggestions on OpenRouter (subject to availability):
#   meta-llama/llama-3.3-70b-instruct:free
#   google/gemini-2.0-flash-exp:free
LLM_MODEL=
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=60
# Max LLM HTTP calls per minute (OpenRouter :free ≈ 16–20). 0 = no pacing.
LLM_MAX_RPM=15

# ── LLM scoring (T-167) ───────────────────────────────────────────────────
# Second opinion during score (requires LLM_ENABLED=true). Default OFF.
LLM_SCORING_ENABLED=false
LLM_SCORING_DETERMINISTIC_WEIGHT=0.7
LLM_SCORING_LLM_WEIGHT=0.3

# ── Semantic embeddings (T-247, Fase 19) ───────────────────────────────────
# Uses same LLM_BASE_URL + LLM_API_KEY. Default OFF.
EMBEDDINGS_ENABLED=false
# e.g. openai/text-embedding-3-small on OpenRouter
EMBEDDING_MODEL=

# ── GitHub collector (T-162) ──────────────────────────────────────────────
# Optional. With token: 5000 req/h. Without: 60 req/h.
GITHUB_TOKEN=

# ── RSS collect (T-161) ───────────────────────────────────────────────────
# Concurrent source fetches (bounded for the 1 vCPU cluster).
AI_RADAR_COLLECT_CONCURRENCY=2
# Max feed entries ingested per source per `ai-radar collect` run.
AI_RADAR_MAX_ITEMS_PER_RUN=50
