{
  "name": "static",
  "version": "1.0.0",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "upload": "sh ./upload.sh dist",
    "copy-assets": "cp *.css dist/ && cp *.html dist/ && cp *.ico dist/",
    "ts-build": "tsc && npm run copy-assets",
    "ts-build-and-upload": "npm run ts-build && npm run upload",
    "build": "webpack --config webpack.config.prod.js",
    "build-and-upload": "npm run build && npm run copy-assets && npm run upload",
    "watch-build-and-upload": "nodemon --ignore dist --ext ts,css,html,ico --exec npm run build-and-upload",
    "start": "webpack-dev-server"
  },
  "author": "@dnorio",
  "license": "UNLICENSED",
  "description": "",
  "devDependencies": {
    "@types/google.maps": "3.55.9",
    "clean-webpack-plugin": "4.0.0",
    "javascript-obfuscator": "4.1.0",
    "nodemon": "3.1.0",
    "ts-loader": "9.5.1",
    "typescript": "5.4.5",
    "webpack": "5.106.2",
    "webpack-cli": "5.1.4",
    "webpack-dev-server": "5.2.4",
    "webpack-obfuscator": "3.5.1"
  },
  "dependencies": {
    "axios": "^1.17.0"
  },
  "overrides": {
    "uuid": "14.0.0",
    "ws": "^8.20.1",
    "qs": "^6.15.2"
  }
}
