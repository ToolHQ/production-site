<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="agent-meter-proxy"
    Manufacturer="DNOR"
    Version="1.2.3.0"
    UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
    Scope="perMachine"
    InstallerVersion="500"
    Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="MainFeature" Title="agent-meter-proxy" Level="1">
      <ComponentRef Id="MainExecutable" />
      <ComponentRef Id="ApplicationShortcut" />
    </Feature>

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="AgentMeterProxy">
          <Component Id="MainExecutable" Guid="*">
            <File
              Id="AgentMeterProxyExe"
              Source="$(var.SourceDir)/agent-meter-proxy-windows-x86_64.exe"
              Name="agent-meter-proxy.exe"
              KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="AgentMeterProxy">
          <Component Id="ApplicationShortcut" Guid="*">
            <Shortcut
              Id="ApplicationStartMenuShortcut"
              Name="agent-meter-proxy"
              Description="AI IDE/CLI Telemetry Proxy"
              Target="[INSTALLFOLDER]agent-meter-proxy.exe"
              WorkingDirectory="INSTALLFOLDER" />
            <RemoveFolder Id="CleanUpStartMenuFolder" Directory="ApplicationProgramsFolder" On="uninstall" />
            <RegistryValue Root="HKCU" Key="Software\agent-meter-proxy" Name="installed" Type="integer" Value="1" KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>
    </Directory>
  </Package>
</Wix>
