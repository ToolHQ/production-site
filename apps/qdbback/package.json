      "text-summary",
      "html",
      "cobertura"
    ],
    "transform": {},
    "setupFiles": [
      "./testingHelpers.js"
    ]
  },
  "scripts": {
    "test-official": "node --experimental-vm-modules node_modules/.bin/jest && ./node_modules/.bin/eslint .",
    "test-from-local-jest-repo": "NODE_OPTIONS=\"--trace-warnings --experimental-vm-modules\" ../../jest/jest && ./node_modules/.bin/eslint .",
    "lint": "./node_modules/.bin/eslint .",
    "test": "./node_modules/.bin/eslint . && node --experimental-vm-modules ./node_modules/@dnorio/jest/index.js"
  },
  "standard": {
    "globals": [
      "fetch",
      "cancelAnimationFrame",
      "requestAnimationFrame",
      "localStorage",
      "test",
      "expect"
    ]
  }
