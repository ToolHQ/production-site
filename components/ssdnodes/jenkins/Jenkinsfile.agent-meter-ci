/**
 * Jenkinsfile.agent-meter-ci — CI pipeline for agent-meter (build + test + lint + sonar)
 *
 * Parametrized: BRANCH_OR_HASH (any branch name or commit SHA)
 * Stages: checkout → clippy → test → sonar-scan → SARIF upload
 *
 * Runs on SSDNodes (12 vCPU / 60GB RAM) — zero GitHub Actions cost.
 */

pipeline {
  agent {
    kubernetes {
      yaml '''
apiVersion: v1
kind: Pod
metadata:
  labels:
    jenkins: agent-meter-ci
spec:
  containers:
  - name: rust
    image: rust:1.88-bookworm
    command: ["sleep"]
    args: ["infinity"]
    tty: true
    resources:
      requests:
        cpu: "2"
        memory: "4Gi"
      limits:
        cpu: "8"
        memory: "16Gi"
    volumeMounts:
    - name: cargo-cache
      mountPath: /usr/local/cargo/registry
    - name: target-cache
      mountPath: /workspace/apps/agent-meter/target
  volumes:
  - name: cargo-cache
    emptyDir: {}
  - name: target-cache
    emptyDir: {}
'''
    }
  }

  parameters {
    string(name: 'BRANCH_OR_HASH', defaultValue: 'main', description: 'Branch name or commit SHA to build')
    booleanParam(name: 'RUN_SONAR', defaultValue: true, description: 'Run SonarQube analysis')
    booleanParam(name: 'UPLOAD_SARIF', defaultValue: false, description: 'Upload clippy SARIF to GitHub Code Scanning')
  }

  environment {
    CARGO_TERM_COLOR = 'always'
    CARGO_INCREMENTAL = '0'
    RUSTFLAGS = '-D warnings'
    SONAR_HOST_URL = 'https://sonar.ssdnodes.dnor.io'
    SONAR_PROJECT_KEY = 'agent-meter'
    SONAR_TOKEN = credentials('sonar-token')
    GITHUB_REPOSITORY = 'ToolHQ/production-site'
  }

  options {
    skipDefaultCheckout(true)
    timeout(time: 30, unit: 'MINUTES')
    disableConcurrentBuilds(abortPrevious: true)
    buildDiscarder(logRotator(numToKeepStr: '30'))
  }

  stages {
    stage('Checkout') {
      steps {
        container('rust') {
          checkout scm
          sh """#!/usr/bin/env bash
set -euo pipefail
git config --global --add safe.directory "\${WORKSPACE}"
git fetch --all --prune
if git rev-parse --verify "origin/${params.BRANCH_OR_HASH}" >/dev/null 2>&1; then
  git checkout "origin/${params.BRANCH_OR_HASH}"
elif git cat-file -t "${params.BRANCH_OR_HASH}" >/dev/null 2>&1; then
  git checkout "${params.BRANCH_OR_HASH}"
else
  echo "ERROR: '${params.BRANCH_OR_HASH}' is neither a valid branch nor commit hash"
  exit 1
fi
echo "Building: \$(git log --oneline -1)"
"""
        }
      }
    }

    stage('Clippy (Lint)') {
      steps {
        container('rust') {
          sh '''#!/usr/bin/env bash
set -euo pipefail
cd apps/agent-meter
rustup component add clippy

# Generate SARIF output for potential GitHub upload
if [ "${UPLOAD_SARIF}" = "true" ]; then
  cargo install clippy-sarif sarif-fmt 2>/dev/null || true
  cargo clippy --workspace --all-targets --message-format=json 2>&1 \
    | clippy-sarif > clippy-results.sarif 2>/dev/null || true
fi

# Normal clippy run (fail on warnings)
cargo clippy --workspace --all-targets -- -D warnings
echo "✓ Clippy: zero warnings"
'''
        }
      }
    }

    stage('Test') {
      steps {
        container('rust') {
          sh '''#!/usr/bin/env bash
set -euo pipefail
cd apps/agent-meter
cargo test --workspace --no-fail-fast 2>&1
echo "✓ All tests passed"
'''
        }
      }
    }

    stage('Build (release)') {
      steps {
        container('rust') {
          sh '''#!/usr/bin/env bash
set -euo pipefail
cd apps/agent-meter
cargo build --release --workspace
echo "✓ Release build OK"
ls -lh target/release/agent-meter-collector target/release/agent-meter-proxy 2>/dev/null || true
'''
        }
      }
    }

    stage('SonarQube Analysis') {
      when {
        expression { return params.RUN_SONAR }
      }
      steps {
        container('rust') {
          sh '''#!/usr/bin/env bash
set -euo pipefail

if [ -z "${SONAR_TOKEN:-}" ]; then
  echo "SONAR_TOKEN not set — skipping"
  exit 0
fi

# Install sonar-scanner if needed
if ! command -v sonar-scanner >/dev/null 2>&1; then
  export DEBIAN_FRONTEND=noninteractive
  apt-get update -qq
  apt-get install -y -qq --no-install-recommends unzip openjdk-17-jre-headless ca-certificates curl
  SONAR_VERSION="7.1.0.4889"
  curl -sSL "https://binaries.sonarsource.com/Distribution/sonar-scanner-cli/sonar-scanner-cli-${SONAR_VERSION}-linux-x64.zip" -o /tmp/sonar.zip
  unzip -q /tmp/sonar.zip -d /opt
  ln -sf /opt/sonar-scanner-*/bin/sonar-scanner /usr/local/bin/sonar-scanner
fi

cd apps/agent-meter
sonar-scanner \
  -Dsonar.projectKey="${SONAR_PROJECT_KEY}" \
  -Dsonar.projectName="agent-meter" \
  -Dsonar.host.url="${SONAR_HOST_URL}" \
  -Dsonar.token="${SONAR_TOKEN}" \
  -Dsonar.sources=crates \
  -Dsonar.exclusions="**/target/**,**/ui/**/*.html" \
  -Dsonar.tests=crates \
  -Dsonar.test.inclusions="**/*_test.rs,**/tests/**" \
  -Dsonar.sourceEncoding=UTF-8 \
  -Dsonar.scm.revision="$(git rev-parse HEAD)"

echo "✓ SonarQube analysis submitted"
'''
        }
      }
    }

    stage('SARIF Upload') {
      when {
        expression { return params.UPLOAD_SARIF }
      }
      steps {
        container('rust') {
          withCredentials([usernamePassword(credentialsId: 'github-pat', usernameVariable: 'GIT_USER', passwordVariable: 'GITHUB_TOKEN')]) {
            sh '''#!/usr/bin/env bash
set -euo pipefail
cd apps/agent-meter

if [ ! -f clippy-results.sarif ]; then
  echo "No SARIF file found — skipping upload"
  exit 0
fi

# Compress and upload SARIF to GitHub Code Scanning
gzip -c clippy-results.sarif | base64 -w0 > sarif.b64
COMMIT_SHA=$(git rev-parse HEAD)
REF=$(git symbolic-ref HEAD 2>/dev/null || echo "refs/heads/main")

curl -sSL -X POST \
  -H "Authorization: token ${GITHUB_TOKEN}" \
  -H "Accept: application/vnd.github+json" \
  "https://api.github.com/repos/${GITHUB_REPOSITORY}/code-scanning/sarifs" \
  -d "{
    \"commit_sha\": \"${COMMIT_SHA}\",
    \"ref\": \"${REF}\",
    \"sarif\": \"$(cat sarif.b64)\",
    \"tool_name\": \"clippy\"
  }"

echo "✓ SARIF uploaded to GitHub Code Scanning"
'''
          }
        }
      }
    }
  }

  post {
    success {
      echo "✓ agent-meter CI pipeline PASSED (${params.BRANCH_OR_HASH})"
    }
    failure {
      echo "✗ agent-meter CI pipeline FAILED (${params.BRANCH_OR_HASH})"
    }
    always {
      script {
        def sha = sh(returnStdout: true, script: 'git rev-parse --short HEAD 2>/dev/null || echo "n/a"').trim()
        echo "Branch/Hash: ${params.BRANCH_OR_HASH} | Commit: ${sha}"
      }
    }
  }
}
