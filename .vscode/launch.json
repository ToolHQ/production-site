{
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch back-end local",
      "program": "${workspaceFolder}/apps/back-end/src/app.ts",
      "preLaunchTask": "npm: build - apps/back-end",
      "outFiles": ["${workspaceFolder}/apps/back-end/dist/**/*.js"]
    },
    {
      "type": "node",
      "request": "attach",
      "name": "Attach to back-end",
      "outFiles": ["${workspaceFolder}/apps/back-end/dist/**/*.js"]
    }
  ]
}